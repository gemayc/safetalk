# Environment Variables
# Copiar este archivo a .env y completar con tus valores

# OpenAI API (si usas GPT para alguna funcionalidad adicional)
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face (para descargar modelos privados si los hay)
HF_TOKEN=your_huggingface_token_here

# Weights & Biases (para tracking de experimentos)
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=safetalk
WANDB_ENTITY=your_entity_here

# MLflow (alternativa para tracking)
MLFLOW_TRACKING_URI=http://localhost:5000

# Configuración de modelos
MODEL_CACHE_DIR=./models/.cache
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
